@using StudentManagementSystem.ViewModels
@model List<CourseEvaluation>
@{
    var course = ViewBag.Course as Course;
    var evaluationTypes = ViewBag.EvaluationTypes as List<EvaluationType>;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Evaluations for @course?.CourseName</h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#createEvaluationModal">
                            <i class="fas fa-plus"></i> Add Evaluation
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Type</th>
                                        <th>Weight</th>
                                        <th>Due Date</th>
                                        <th>Max Score</th>
                                        <th>Status</th>
                                        <th>Submissions</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var evaluation in Model)
                                    {
                                        <tr>
                                            <td>@evaluation.Title</td>
                                            <td>@evaluation.EvaluationType?.Name</td>
                                            <td>@evaluation.Weight%</td>
                                            <td>@evaluation.DueDate?.ToString("MMM dd, yyyy")</td>
                                            <td>@evaluation.MaxScore</td>
                                            <td>
                                                <span class="badge badge-@(evaluation.IsPublished ? "success" : "secondary")">
                                                    @(evaluation.IsPublished ? "Published" : "Draft")
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge badge-info">@evaluation.TotalSubmissions / @course?.CurrentEnrollment</span>
                                            </td>
                                            <td>
                                                <a href="@Url.Action("GradeEvaluation", new { evaluationId = evaluation.Id })"
                                                   class="btn btn-primary btn-sm">
                                                    <i class="fas fa-edit"></i> Grade
                                                </a>
                                                <a href="@Url.Action("ImportGrades", new { evaluationId = evaluation.Id })"
                                                   class="btn btn-success btn-sm">
                                                    <i class="fas fa-file-import"></i> Import
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <h5><i class="fas fa-info-circle"></i> No Evaluations Created</h5>
                            <p>Create your first evaluation to start grading students.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Evaluation Modal -->
<div class="modal fade" id="createEvaluationModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create New Evaluation</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <form asp-action="CreateEvaluation" method="post">
                <input type="hidden" name="CourseId" value="@course?.Id" />
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Evaluation Type</label>
                                <select name="EvaluationTypeId" class="form-control" required>
                                    <option value="">Select Type</option>
                                    @if (evaluationTypes != null)
                                    {
                                        @foreach (var type in evaluationTypes)
                                        {
                                            <option value="@type.Id">@type.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Title</label>
                                <input type="text" name="Title" class="form-control" required placeholder="e.g., Final Exam, Assignment 1" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Weight (%)</label>
                                <input type="number" name="Weight" class="form-control" min="0" max="100" step="0.1" required value="20" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Max Score</label>
                                <input type="number" name="MaxScore" class="form-control" min="0" max="1000" step="0.1" required value="100" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Due Date</label>
                                <input type="date" name="DueDate" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Evaluation Date</label>
                                <input type="date" name="EvaluationDate" class="form-control" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Description</label>
                        <textarea name="Description" class="form-control" rows="3" placeholder="Evaluation description..."></textarea>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" name="IsPublished" class="form-check-input" id="isPublished" />
                        <label class="form-check-label" for="isPublished">Publish immediately</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Evaluation</button>
                </div>
            </form>
        </div>
    </div>
</div>