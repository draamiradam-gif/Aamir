@model List<Course>

@{
    ViewData["Title"] = "Select Course for Final Grades";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">@ViewData["Title"]</h3>
                    <div class="card-tools">
                        <a asp-action="Dashboard" class="btn btn-secondary btn-sm">
                            <i class="fas fa-arrow-left"></i> Back to Dashboard
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model == null || !Model.Any())
                    {
                        <div class="alert alert-warning">
                            <h5><i class="fas fa-exclamation-triangle"></i> No Courses Available</h5>
                            <p>There are no active courses available for final grade calculation.</p>
                        </div>
                    }
                    else
                    {
                        <div class="row">
                            @foreach (var course in Model)
                            {
                                <div class="col-md-4 mb-4">
                                    <div class="card course-card">
                                        <div class="card-header bg-success text-white">
                                            <h5 class="card-title mb-0">@course.CourseCode</h5>
                                        </div>
                                        <div class="card-body">
                                            <h6 class="card-subtitle mb-2">@course.CourseName</h6>
                                            <p class="card-text">
                                                <small class="text-muted">
                                                    Credits: @course.Credits<br>
                                                    Department: @course.Department
                                                </small>
                                            </p>
                                        </div>
                                        <div class="card-footer">
                                            <a asp-action="CourseFinalGrades" asp-route-courseId="@course.Id"
                                               class="btn btn-success btn-block">
                                                <i class="fas fa-calculator"></i> Calculate Final Grades
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>