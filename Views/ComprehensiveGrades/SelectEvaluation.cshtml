@model List<CourseEvaluation>

@{
    ViewData["Title"] = "Select Evaluation for Grade Import";
}

<div class="alert alert-warning">
    <h5>Debug - Evaluations:</h5>
    @foreach (var eval in Model.Take(5))
    {
        <div>Evaluation: @eval.Title | ID: @eval.Id | Course: @eval.Course?.CourseName</div>
    }
    <div>Total Evaluations: @Model.Count | Valid IDs: @Model.Count(e => e.Id > 0)</div>
</div>
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">@ViewData["Title"]</h3>
                    <div class="card-tools">
                        <a asp-action="Dashboard" class="btn btn-secondary btn-sm">
                            <i class="fas fa-arrow-left"></i> Back to Dashboard
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model == null || !Model.Any())
                    {
                        <div class="alert alert-warning">
                            <h5><i class="fas fa-exclamation-triangle"></i> No Evaluations Available</h5>
                            <p>There are no evaluations available for grade import. Please create evaluations first.</p>
                            <a asp-action="CourseEvaluations" class="btn btn-primary">Create Evaluations</a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped">
                                <thead class="thead-dark">
                                    <tr>
                                        <th>Evaluation</th>
                                        <th>Course</th>
                                        <th>Type</th>
                                        <th>Due Date</th>
                                        <th>Weight</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var evaluation in Model)
                                    {
                                        <tr>
                                            <td>@evaluation.Title</td>
                                            <td>@evaluation.Course?.CourseName</td>
                                            <td>@evaluation.EvaluationType?.Name</td>
                                            <td>@evaluation.DueDate?.ToString("yyyy-MM-dd")</td>
                                            <td>@evaluation.Weight%</td>
                                            <td>
                                                <!-- ADD ID VALIDATION -->
                                                @if (evaluation.Id > 0)
                                                {
                                                    <a asp-action="ImportGrades" asp-route-evaluationId="@evaluation.Id"
                                                       class="btn btn-primary btn-sm">
                                                        <i class="fas fa-file-import"></i> Import Grades
                                                    </a>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-secondary btn-sm" disabled>
                                                        Invalid Evaluation
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>