@model List<CourseEvaluation>
@{
    ViewData["Title"] = "Select Evaluation for Statistics";
    var evaluations = Model ?? new List<CourseEvaluation>();
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Select Evaluation for Statistics</h3>
                    <p class="card-subtitle">Choose an evaluation to view performance analytics</p>
                </div>
                <div class="card-body">
                    @if (evaluations.Any())
                    {
                        <div class="list-group">
                            @foreach (var evaluation in evaluations)
                            {
                                <a href="@Url.Action("EvaluationStatistics", new { evaluationId = evaluation.Id })"
                                   class="list-group-item list-group-item-action">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h5 class="mb-1">@evaluation.Title</h5>
                                        <small>@evaluation.EvaluationType?.Name</small>
                                    </div>
                                    <p class="mb-1">@evaluation.Course?.CourseName</p>
                                    <small>Average: @evaluation.AverageScore.ToString("0.00") | Submissions: @evaluation.TotalSubmissions</small>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <h5><i class="fas fa-exclamation-triangle"></i> No Graded Evaluations Available</h5>
                            <p>There are no graded evaluations available for statistics. Please grade some evaluations first.</p>
                            <a href="@Url.Action("Dashboard")" class="btn btn-primary">Go to Dashboard</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>